          {
            "cursor": "#008050",
            "background": "#008050",
            "selection": "#bcb8b0"
          }
        ],
        "syntax": {
          "keyword": {
            "color": "#1050a8",
            "font_weight": 700
          },
          "function": {
            "color": "#701888",
            "font_weight": 700
          },
          "comment": {
            "color": "#086068",
            "font_style": "italic"
          },
          "comment.doc": {
            "color": "#086068",
            "font_style": "italic"
          },
          "string": {
            "color": "#008050"
          },
          "string.escape": {
            "color": "#1048b0",
            "font_weight": 700
          },
          "string.regex": {
            "color": "#1048b0"
          },
          "string.special": {
            "color": "#1048b0"
          },
          "number": {
            "color": "#801890"
          },
          "boolean": {
            "color": "#5020a0"
          },
          "constant": {
            "color": "#2828c0"
          },
          "type": {
            "color": "#1050a8"
          },
          "constructor": {
            "color": "#488820"
          },
          "variable": {
            "color": "#252028"
          },
          "variable.special": {
            "color": "#1050a8",
            "font_weight": 700
          },
          "property": {
            "color": "#1850a0"
          },
          "operator": {
            "color": "#1840b8"
          },
          "punctuation": {
            "color": "#108868"
          },
          "punctuation.bracket": {
            "color": "#108868"
          },
          "punctuation.delimiter": {
            "color": "#108868"
          },
          "punctuation.special": {
            "color": "#1048b0"
          },
          "tag": {
            "color": "#7018a8"
          },
          "attribute": {
            "color": "#007048"
          },
          "namespace": {
            "color": "#5820c0"
          },
          "label": {
            "color": "#6018b8"
          },
          "preproc": {
            "color": "#801890"
          },
          "emphasis": {
            "font_style": "italic"
          },
          "emphasis.strong": {
            "font_weight": 700
          },
          "title": {
            "color": "#1050a8",
            "font_weight": 700
          },
          "text.literal": {
            "color": "#008050"
          },
          "link_text": {
            "color": "#701888"
          },
          "link_uri": {
            "color": "#086068"
          },
          "enum": {
            "color": "#1050a8"
          },
          "variant": {
            "color": "#2828c0"
          }
        }
